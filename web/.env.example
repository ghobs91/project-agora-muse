# Agora Muse OAuth Configuration
# Copy this file to .env.local and fill in your values.

# OAuth client ID (the URL where your client-metadata.json is hosted)
NEXT_PUBLIC_OAUTH_CLIENT_ID=http://localhost:3000/client-metadata.json

# OAuth client URI (your app's canonical URL)
NEXT_PUBLIC_OAUTH_CLIENT_URI=http://localhost:3000

# OAuth redirect URI (where Bluesky sends the user after authorization)
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
